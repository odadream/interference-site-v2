{
  "name": "interference-site-v2",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "npm run analytics:check",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,js,jsx}\" \"*.html\" \"*.json\" \"*.js\" \"*.ts\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,js,jsx}\" \"*.html\" \"*.json\" \"*.js\" \"*.ts\"",
    "preview": "vite preview",
    "analytics:check": "node scripts/analytics-config.mjs check",
    "analytics:verify-build": "node scripts/analytics-config.mjs verify-dist"
  },
  "dependencies": {
    "katex": "^0.16.45",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@types/katex": "^0.16.8",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "postcss": "^8.5.12",
    "prettier": "^3.8.3",
    "tailwindcss": "^3.4.19",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10"
  }
}
